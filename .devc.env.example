# Devcontainer environment variables
# Copy to .devc.env and fill in your values: cp .devc.env.example .devc.env
# Parsed by `devc` before building/starting the container (not shell-sourced).
# NEVER commit .devc.env — it is gitignored.

# Required — GitHub fine-grained PAT (scoped to your repos)
GH_TOKEN=

# Required — Azure OpenAI API key (for Codex CLI / /review-pr)
OPENAI_API_KEY=

# Required — Azure OpenAI endpoint URL
CODEX_AZURE_BASE_URL=

# Optional — Anthropic API key (bypasses interactive `claude login`)
ANTHROPIC_API_KEY=

# Optional — Exa AI search (used by Claude skills)
EXA_API_KEY=

# Optional — Gemini CLI (second opinion on PR reviews)
GEMINI_API_KEY=

# Optional — Tailscale OAuth client credentials (for tailscale sidecar)
TS_CLIENT_ID=
TS_CLIENT_SECRET=
TS_HOSTNAME=ts-devc-omoser

# amd64
#TS_IMAGE_SHA=sha256:5f7d41e691ebdb4dcf6c92e89f4624db3883ffd0afb3a3436ec18dff847b0a73

# arm64
TS_IMAGE_SHA=sha256:3e3bebce61524ec3fc416ecafba5b378a4d26d1609d5af8d25c9f49d4bb1ff59

# Optional — publish a container port to the host (omit to skip)
# DEVC_PUBLISH_PORT=8000

# Optional — bind address for published port (default: 127.0.0.1, use 0.0.0.0 for remote access)
# DEVC_BIND_HOST=127.0.0.1

# Optional — GPU passthrough: "all" or number of GPUs (requires NVIDIA Container Toolkit)
# DEVC_GPU=all

# Optional — SSH key for signed git commits (absolute path on host)
# GIT_SIGNING_KEY=~/.ssh/id_ed25519
